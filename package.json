{
	"name": "@fhir-zod/core",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./r4": {
			"types": "./dist/r4/index.d.ts",
			"import": "./dist/r4/index.js"
		},
		"./r4b": {
			"types": "./dist/r4b/index.d.ts",
			"import": "./dist/r4b/index.js"
		},
		"./r5": {
			"types": "./dist/r5/index.d.ts",
			"import": "./dist/r5/index.js"
		},
		"./stu3": {
			"types": "./dist/stu3/index.d.ts",
			"import": "./dist/stu3/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "npm run typecheck && tsdown",
		"check": "biome check .",
		"compare:r4": "node scripts/compare-r4.ts",
		"coverage": "vitest run --coverage",
		"fetch-examples": "node scripts/fetch-examples.ts",
		"fetch-spec": "node scripts/fetch-spec.ts",
		"format": "biome format --write .",
		"generate": "node scripts/generate.ts",
		"generate:r4:openapi": "node scripts/generate-r4-openapi.ts",
		"lint": "biome lint .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.3",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^3.2.4",
		"tsdown": "^0.15.5",
		"typescript": "^5.8.2",
		"vitest": "^3.1.1",
		"zod": "^3.25.0"
	}
}
